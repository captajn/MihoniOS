  "strings": {
    "about_dont_kill_my_app": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Some manufacturers have additional app restrictions that kill background services. This website has more info on how to fix it."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Một vài nhà sản xuất có các hạn chế về việc chạy ngầm của ứng dụng có thể gây dừng hiện thị dịch vụ nền. Xem thêm ở địa chỉ này để sửa chữa chúng."
          }
        }
      }
    },
