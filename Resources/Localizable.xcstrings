    "donationCampaign.dismiss": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dismiss"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Miễn nhiệm"
          }
        }
      }
    },
    "donationCampaign.paragraph1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hi! I’m the main developer behind Mihon, and I’d like to ask you to consider supporting its development financially. With enough support, I’ll be able to work on Mihon full-time and focus on long-standing issues as well as highly requested features."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chào! Tôi là nhà phát triển chính đằng sau Mihon và tôi muốn đề nghị bạn xem xét hỗ trợ tài chính cho sự phát triển của nó. Nếu có đủ sự hỗ trợ, tôi sẽ có thể làm việc toàn thời gian trên Mihon và tập trung vào các vấn đề tồn tại lâu dài cũng như các tính năng được yêu cầu cao."
          }
        }
      }
    },
    "donationCampaign.paragraph2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can donate through either Patreon (preferred) or OpenCollective. If you have questions or would like to support using alternative methods, feel free to reach out to me through Mihon's Discord server."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có thể quyên góp thông qua Patreon (ưu tiên) hoặc OpenCollective. Nếu bạn có thắc mắc hoặc muốn hỗ trợ bằng các phương pháp thay thế, vui lòng liên hệ với tôi thông qua máy chủ Discord của Mihon."
          }
        }
      }
    },
    "donationCampaign.paragraph3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Regardless, Mihon will continue to be maintained by me and the volunteers, and it will stay open source."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dù thế nào đi nữa, Mihon sẽ tiếp tục được tôi và các tình nguyện viên duy trì và nó sẽ vẫn là nguồn mở."
          }
        }
      }
    },
    "donationCampaign.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enjoying the app?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn thích ứng dụng này?"
          }
        }
      }
    },
